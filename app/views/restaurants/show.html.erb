<div class="container mt-3">
  <h1><%= @restaurant.name %></h1>
  <p class="text-muted"><%= @restaurant.category %> - <%= @restaurant.address %></p>
  <p><%= @restaurant.phone_number %></p>

  <hr>

  <h3>Reviews</h3>
  <ul class="list-group">
    <% @restaurant.reviews.each do |review| %>
      <li class="list-group-item">
        <strong><%= review.rating %> / 5</strong> - <%= review.content %>
      </li>
    <% end %>
  </ul>

  <%= link_to "Back to list", restaurants_path, class: "btn btn-secondary mt-3" %>
</div>
<hr>
<h3>Add a review</h3>
<%= simple_form_for [@restaurant, Review.new] do |f| %>
  <%= f.input :content %>
  <%= f.input :rating, collection: 0..5 %>
  <%= f.button :submit, class: "btn btn-primary" %>
<% end %>
